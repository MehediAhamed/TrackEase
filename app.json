{
  "expo": {
    "name": "TrackEase",
    "slug": "trackease",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "trackease",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vlmrun.trackease",
      "infoPlist": {
        "NSCameraUsageDescription": "TrackEase uses your camera to scan product seals, barcodes, and labels.",
        "NSPhotoLibraryAddUsageDescription": "TrackEase saves scan results to your photo library.",
        "NSPhotoLibraryUsageDescription": "TrackEase accesses your photo library to scan saved images.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E1A"
      },
      "package": "com.vlmrun.trackease",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "TrackEase uses your camera to scan product labels, barcodes, and seals."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TrackEase accesses your photos to scan product labels."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "TrackEase saves scan results to your photo library.",
          "savePhotosPermission": "TrackEase saves scan results to your photo library."
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "24294cc2-6e20-42ae-9ad0-b4c5f2941ed3"
      }
    }
  }
}
